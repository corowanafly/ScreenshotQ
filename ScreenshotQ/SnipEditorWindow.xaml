<Window x:Class="ScreenshotQ.SnipEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Snip Editor"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#1A1A1A"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <ContextMenu x:Key="ColorPickerMenu">
            <MenuItem Header="Red" Tag="#FF1744" Click="ColorMenuItem_Click">
                <MenuItem.Icon>
                    <Border Width="12" Height="12" Background="#FF1744" CornerRadius="2"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Orange" Tag="#FF6D00" Click="ColorMenuItem_Click">
                <MenuItem.Icon>
                    <Border Width="12" Height="12" Background="#FF6D00" CornerRadius="2"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Green" Tag="#00E676" Click="ColorMenuItem_Click">
                <MenuItem.Icon>
                    <Border Width="12" Height="12" Background="#00E676" CornerRadius="2"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Blue" Tag="#00B0FF" Click="ColorMenuItem_Click">
                <MenuItem.Icon>
                    <Border Width="12" Height="12" Background="#00B0FF" CornerRadius="2"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Purple" Tag="#D500F9" Click="ColorMenuItem_Click">
                <MenuItem.Icon>
                    <Border Width="12" Height="12" Background="#D500F9" CornerRadius="2"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Yellow" Tag="#FFEA00" Click="ColorMenuItem_Click">
                <MenuItem.Icon>
                    <Border Width="12" Height="12" Background="#FFEA00" CornerRadius="2"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="White" Tag="#FFFFFF" Click="ColorMenuItem_Click">
                <MenuItem.Icon>
                    <Border Width="12" Height="12" Background="#FFFFFF" BorderBrush="#94A3B8" BorderThickness="1" CornerRadius="2"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <ContextMenu x:Key="StrokePickerMenu">
            <MenuItem Header="Thin" Tag="2" Click="StrokeMenuItem_Click">
                <MenuItem.Icon>
                    <Rectangle Width="12" Height="2" Fill="#E2E8F0" RadiusX="1" RadiusY="1"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Medium" Tag="4" Click="StrokeMenuItem_Click">
                <MenuItem.Icon>
                    <Rectangle Width="12" Height="4" Fill="#E2E8F0" RadiusX="2" RadiusY="2"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Bold" Tag="6" Click="StrokeMenuItem_Click">
                <MenuItem.Icon>
                    <Rectangle Width="12" Height="6" Fill="#E2E8F0" RadiusX="2" RadiusY="2"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="ToolbarIconToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="#223047"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30445F"/>
                    <Setter Property="BorderBrush" Value="#4A6788"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#0EA5E9"/>
                    <Setter Property="BorderBrush" Value="#38BDF8"/>
                    <Setter Property="Foreground" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="#162236"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#223047"/>
                    <Setter Property="BorderBrush" Value="#4A6788"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarActionButtonStyle}">
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="BorderBrush" Value="#38BDF8"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38BDF8"/>
                    <Setter Property="BorderBrush" Value="#7DD3FC"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0284C7"/>
                    <Setter Property="BorderBrush" Value="#38BDF8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid x:Name="SurfaceRoot" ClipToBounds="True">
            <Image x:Name="FrozenImage" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Rectangle x:Name="DimOverlay"
                       Fill="#6B111827"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       IsHitTestVisible="False"/>

            <Image x:Name="SelectedPreview"
                     Stretch="Fill"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"/>

            <Canvas x:Name="OverlayCanvas"
                    Background="#01000000"
                    MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"
                    MouseMove="OverlayCanvas_MouseMove"
                    MouseLeftButtonUp="OverlayCanvas_MouseLeftButtonUp">
                <Rectangle x:Name="SelectionRectangle"
                           Visibility="Collapsed"
                           Stroke="#38BDF8"
                           Fill="Transparent"
                           StrokeThickness="2"
                           StrokeDashArray="4,4"
                           IsHitTestVisible="False"
                           Panel.ZIndex="999"/>

                <Thumb x:Name="TopLeftThumb" Tag="TopLeft" Width="10" Height="10" Cursor="SizeNWSE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="TopThumb" Tag="Top" Width="10" Height="10" Cursor="SizeNS" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="TopRightThumb" Tag="TopRight" Width="10" Height="10" Cursor="SizeNESW" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="RightThumb" Tag="Right" Width="10" Height="10" Cursor="SizeWE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="BottomRightThumb" Tag="BottomRight" Width="10" Height="10" Cursor="SizeNWSE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="BottomThumb" Tag="Bottom" Width="10" Height="10" Cursor="SizeNS" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="BottomLeftThumb" Tag="BottomLeft" Width="10" Height="10" Cursor="SizeNESW" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="LeftThumb" Tag="Left" Width="10" Height="10" Cursor="SizeWE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>

                <Thumb x:Name="ShapeTopLeftThumb" Tag="ShapeTopLeft" Width="10" Height="10" Cursor="SizeNWSE" Background="#F8FAFC" BorderBrush="#F97316" BorderThickness="1" DragDelta="ShapeResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1002"/>
                <Thumb x:Name="ShapeTopRightThumb" Tag="ShapeTopRight" Width="10" Height="10" Cursor="SizeNESW" Background="#F8FAFC" BorderBrush="#F97316" BorderThickness="1" DragDelta="ShapeResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1002"/>
                <Thumb x:Name="ShapeBottomRightThumb" Tag="ShapeBottomRight" Width="10" Height="10" Cursor="SizeNWSE" Background="#F8FAFC" BorderBrush="#F97316" BorderThickness="1" DragDelta="ShapeResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1002"/>
                <Thumb x:Name="ShapeBottomLeftThumb" Tag="ShapeBottomLeft" Width="10" Height="10" Cursor="SizeNESW" Background="#F8FAFC" BorderBrush="#F97316" BorderThickness="1" DragDelta="ShapeResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1002"/>
                <Thumb x:Name="ArrowStartThumb" Tag="ArrowStart" Width="12" Height="12" Cursor="Hand" Background="#F8FAFC" BorderBrush="#FB7185" BorderThickness="1.2" DragDelta="ArrowEndpointThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1003"/>
                <Thumb x:Name="ArrowEndThumb" Tag="ArrowEnd" Width="12" Height="12" Cursor="Hand" Background="#F8FAFC" BorderBrush="#FB7185" BorderThickness="1.2" DragDelta="ArrowEndpointThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1003"/>

                <Thumb x:Name="TextTopLeftThumb" Tag="TextTopLeft" Width="10" Height="10" Cursor="SizeNWSE" Background="#F8FAFC" BorderBrush="#10B981" BorderThickness="1" DragDelta="TextResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1004"/>
                <Thumb x:Name="TextTopRightThumb" Tag="TextTopRight" Width="10" Height="10" Cursor="SizeNESW" Background="#F8FAFC" BorderBrush="#10B981" BorderThickness="1" DragDelta="TextResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1004"/>
                <Thumb x:Name="TextBottomRightThumb" Tag="TextBottomRight" Width="10" Height="10" Cursor="SizeNWSE" Background="#F8FAFC" BorderBrush="#10B981" BorderThickness="1" DragDelta="TextResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1004"/>
                <Thumb x:Name="TextBottomLeftThumb" Tag="TextBottomLeft" Width="10" Height="10" Cursor="SizeNESW" Background="#F8FAFC" BorderBrush="#10B981" BorderThickness="1" DragDelta="TextResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1004"/>
            </Canvas>
        </Grid>

        <Border x:Name="ToolPanel"
                Panel.ZIndex="20"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="12"
                Background="#EE0F172A"
            Padding="6"
                CornerRadius="12"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ToggleButton x:Name="RectToolButton" Style="{StaticResource ToolbarIconToggleStyle}" Click="ToolButton_Click" ToolTip="Draw rectangle">
                            <Viewbox Width="12" Height="12">
                                <Rectangle Width="14" Height="10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.8" RadiusX="1" RadiusY="1" Fill="Transparent"/>
                            </Viewbox>
                        </ToggleButton>
                        <ToggleButton x:Name="EllipseToolButton" Style="{StaticResource ToolbarIconToggleStyle}" Click="ToolButton_Click" ToolTip="Draw ellipse">
                            <Viewbox Width="12" Height="12">
                                <Ellipse Width="14" Height="10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.8" Fill="Transparent"/>
                            </Viewbox>
                        </ToggleButton>
                        <ToggleButton x:Name="ArrowToolButton" Style="{StaticResource ToolbarIconToggleStyle}" Click="ToolButton_Click" ToolTip="Draw arrow">
                            <Viewbox Width="12" Height="12">
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M2,9 L14,9 M10,5 L14,9 L10,13"/>
                            </Viewbox>
                        </ToggleButton>
                        <ToggleButton x:Name="TextToolButton" Style="{StaticResource ToolbarIconToggleStyle}" Click="ToolButton_Click" ToolTip="Insert text">
                            <TextBlock Text="T"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </ToggleButton>
                        <ToggleButton x:Name="NumberToolButton" Style="{StaticResource ToolbarIconToggleStyle}" Margin="0" Click="ToolButton_Click" ToolTip="Insert numbered marker">
                            <TextBlock Text="#"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </ToggleButton>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource ToolbarActionButtonStyle}" Click="UndoButton_Click" ToolTip="Undo last change">
                            <Viewbox Width="12" Height="12">
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M9,4 C6,4 3.8,6.2 3.8,9.2 M3.8,9.2 L3.8,5.6 M3.8,9.2 L7.4,9.2 M9,4 C12.3,4 14.8,6.7 14.8,10 C14.8,13.3 12.3,16 9,16"/>
                            </Viewbox>
                        </Button>
                        <Button x:Name="ColorButton" Style="{StaticResource ToolbarActionButtonStyle}" Click="ColorButton_Click" ToolTip="Choose annotation color">
                            <Ellipse x:Name="CurrentColorSwatch" Width="12" Height="12" Fill="#FF1744" Stroke="#E2E8F0" StrokeThickness="1"/>
                        </Button>
                        <Button x:Name="StrokeButton" Style="{StaticResource ToolbarActionButtonStyle}" Click="StrokeButton_Click" ToolTip="Choose stroke thickness">
                            <Rectangle x:Name="CurrentStrokePreview" Width="12" Height="4" Fill="#E2E8F0" RadiusX="2" RadiusY="2"/>
                        </Button>
                        <Button Style="{StaticResource ToolbarPrimaryActionButtonStyle}" Margin="3,0,0,0" Click="SaveButton_Click" ToolTip="Save screenshot and copy to clipboard">
                            <Viewbox Width="12" Height="12">
                                <Canvas Width="18" Height="18">
                                    <Rectangle Canvas.Left="3" Canvas.Top="2" Width="12" Height="14" RadiusX="1" RadiusY="1" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" Fill="Transparent"/>
                                    <Rectangle Canvas.Left="6" Canvas.Top="4" Width="6" Height="3" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <Rectangle Canvas.Left="6" Canvas.Top="10" Width="6" Height="4" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.4" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource ToolbarActionButtonStyle}" Margin="3,0,0,0" Click="CopyButton_Click" ToolTip="Copy image and finish">
                            <Viewbox Width="12" Height="12">
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M3.5,9.5 L7.3,13 L14.5,5.8"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource ToolbarActionButtonStyle}" Margin="3,0,0,0" Click="CancelButton_Click" ToolTip="Cancel capture">
                            <Viewbox Width="12" Height="12">
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M4,4 L14,14 M14,4 L4,14"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="HintText"
                           Grid.Row="1"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Foreground="#E2E8F0"
                           Visibility="Collapsed"
                           Text="Drag to select an area. Then annotate and save."/>
            </Grid>
        </Border>
    </Grid>
</Window>
