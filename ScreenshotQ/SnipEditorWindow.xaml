<Window x:Class="ScreenshotQ.SnipEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Snip Editor"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#1A1A1A"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid x:Name="SurfaceRoot" ClipToBounds="True">
            <Image x:Name="FrozenImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Rectangle x:Name="DimOverlay"
                       Fill="#6B111827"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       IsHitTestVisible="False"/>

            <Image x:Name="SelectedPreview"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"/>

            <Canvas x:Name="OverlayCanvas"
                    Background="#01000000"
                    MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"
                    MouseMove="OverlayCanvas_MouseMove"
                    MouseLeftButtonUp="OverlayCanvas_MouseLeftButtonUp">
                <Rectangle x:Name="SelectionRectangle"
                           Visibility="Collapsed"
                           Stroke="#38BDF8"
                           Fill="#1A38BDF8"
                           StrokeThickness="2"
                           StrokeDashArray="4,4"
                           IsHitTestVisible="False"
                           Panel.ZIndex="999"/>

                <Thumb x:Name="TopLeftThumb" Tag="TopLeft" Width="10" Height="10" Cursor="SizeNWSE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="TopThumb" Tag="Top" Width="10" Height="10" Cursor="SizeNS" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="TopRightThumb" Tag="TopRight" Width="10" Height="10" Cursor="SizeNESW" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="RightThumb" Tag="Right" Width="10" Height="10" Cursor="SizeWE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="BottomRightThumb" Tag="BottomRight" Width="10" Height="10" Cursor="SizeNWSE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="BottomThumb" Tag="Bottom" Width="10" Height="10" Cursor="SizeNS" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="BottomLeftThumb" Tag="BottomLeft" Width="10" Height="10" Cursor="SizeNESW" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
                <Thumb x:Name="LeftThumb" Tag="Left" Width="10" Height="10" Cursor="SizeWE" Background="#E2E8F0" BorderBrush="#0EA5E9" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" Visibility="Collapsed" Panel.ZIndex="1001"/>
            </Canvas>
        </Grid>

        <Border x:Name="ToolPanel"
                Panel.ZIndex="20"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="12"
                Background="#EE0F172A"
                Padding="10"
                CornerRadius="10"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <ToggleButton x:Name="SelectToolButton" Content="Select" Width="72" Margin="0,0,8,0" Click="ToolButton_Click" IsChecked="True"/>
                    <ToggleButton x:Name="RectToolButton" Content="Rect" Width="64" Margin="0,0,8,0" Click="ToolButton_Click"/>
                    <ToggleButton x:Name="EllipseToolButton" Content="Ellipse" Width="68" Margin="0,0,8,0" Click="ToolButton_Click"/>
                    <ToggleButton x:Name="ArrowToolButton" Content="Arrow" Width="68" Margin="0,0,8,0" Click="ToolButton_Click"/>
                    <ToggleButton x:Name="TextToolButton" Content="Text" Width="64" Margin="0,0,8,0" Click="ToolButton_Click"/>
                    <ToggleButton x:Name="NumberToolButton" Content="Number" Width="78" Margin="0,0,16,0" Click="ToolButton_Click"/>

                    <Button Content="Clear" Width="70" Margin="0,0,8,0" Click="ClearButton_Click"/>
                    <Button Content="Save" Width="80" Margin="0,0,8,0" Click="SaveButton_Click"/>
                    <Button Content="Cancel" Width="80" Click="CancelButton_Click"/>
                </StackPanel>

                <TextBlock x:Name="HintText"
                           VerticalAlignment="Center"
                           Foreground="#E2E8F0"
                           Text="Drag to select an area. Then annotate and save."/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
